{
    "files.insertFinalNewline": true,
    "editor.fontFamily": "Operator Mono Lig",
    "editor.fontLigatures": true,
    "editor.fontSize": 12,
    "editor.renderWhitespace": "boundary",
    "editor.insertSpaces": false,
    "workbench.startupEditor": "newUntitledFile",
    "workbench.colorCustomizations": {
        "editor.selectionBackground": "#8a427ee3",
        "editor.selectionHighlightBackground": "#135564"
    },
    "html.validate.scripts": false,
    "explorer.confirmDragAndDrop": false,
    "less.lint.duplicateProperties": "warning",
    "less.lint.float": "warning",
    "less.lint.idSelector": "warning",
    "less.lint.important": "warning",
    "less.lint.universalSelector": "warning",
    "less.lint.zeroUnits": "warning",
    "less.validate": false,
    "scss.validate": false,
    "css.validate": false,
    "diffEditor.ignoreTrimWhitespace": true,
    "security.workspace.trust.untrustedFiles": "open",
    "javascript.preferences.quoteStyle": "single",
    "typescript.preferences.quoteStyle": "single",
    "less.completion.triggerPropertyValueCompletion": false,
    "bracketPairColorizer.depreciation-notice": false,
    "json.schemas": [],
    "editor.guides.bracketPairs": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.suggest.showMethods": true,
    "editor.suggest.preview": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.snippetSuggestions": "top",
    "git.mergeEditor": false,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "security.promptForLocalFileProtocolHandling": false,
    "diffEditor.renderSideBySide": true,
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": false
    }
}
